{
  "name": "MemberProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to the User entity id"
    },
    "display_name": {
      "type": "string",
      "description": "Display name on the platform"
    },
    "gender": {
      "type": "string",
      "enum": [
        "female",
        "male"
      ],
      "description": "Gender of the member"
    },
    "age": {
      "type": "number",
      "description": "Age of the member (must be 18+)"
    },
    "date_of_birth": {
      "type": "string",
      "format": "date",
      "description": "Date of birth for age verification"
    },
    "location_city": {
      "type": "string",
      "description": "City"
    },
    "location_country": {
      "type": "string",
      "description": "Country"
    },
    "bio": {
      "type": "string",
      "description": "Profile bio (max 500 chars)"
    },
    "photo_1": {
      "type": "string",
      "description": "Primary profile photo URL (identity photo, cannot be deleted)"
    },
    "photo_2": {
      "type": "string",
      "description": "Second photo URL"
    },
    "photo_3": {
      "type": "string",
      "description": "Third photo URL"
    },
    "photo_1_visible": {
      "type": "boolean",
      "default": true,
      "description": "Whether photo 1 is visible on the profile"
    },
    "photo_2_visible": {
      "type": "boolean",
      "default": true,
      "description": "Whether photo 2 is visible on the profile"
    },
    "photo_3_visible": {
      "type": "boolean",
      "default": true,
      "description": "Whether photo 3 is visible on the profile"
    },
    "instagram": {
      "type": "string",
      "description": "Instagram username"
    },
    "facebook": {
      "type": "string",
      "description": "Facebook profile link"
    },
    "tiktok": {
      "type": "string",
      "description": "TikTok username"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "unverified",
        "pending",
        "verified",
        "rejected"
      ],
      "default": "unverified",
      "description": "ID verification status"
    },
    "id_document_url": {
      "type": "string",
      "description": "Uploaded ID document URL (private)"
    },
    "selfie_url": {
      "type": "string",
      "description": "Selfie for facial matching URL"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the profile is active/visible"
    },
    "is_suspended": {
      "type": "boolean",
      "default": false,
      "description": "Whether the profile is suspended by admin"
    },
    "suspension_reason": {
      "type": "string",
      "description": "Reason for suspension"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "free",
        "active",
        "expired",
        "cancelled"
      ],
      "default": "free",
      "description": "Subscription status (relevant for male users)."
    },
    "subscription_start_date": {
      "type": "string",
      "format": "date",
      "description": "When the paid subscription started"
    },
    "subscription_end_date": {
      "type": "string",
      "format": "date",
      "description": "When the paid subscription expires"
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of interests/hobbies"
    },
    "looking_for": {
      "type": "string",
      "enum": [
        "relationship",
        "friendship",
        "casual",
        "marriage"
      ],
      "description": "What the member is looking for"
    },
    "profile_complete": {
      "type": "boolean",
      "default": false,
      "description": "Whether the profile setup is complete"
    }
  },
  "required": [
    "user_id",
    "display_name",
    "gender"
  ]
}